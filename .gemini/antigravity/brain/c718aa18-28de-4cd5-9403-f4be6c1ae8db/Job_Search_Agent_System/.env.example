# Job Search Agent — variables d'environnement
# Copier en .env et renseigner les valeurs
#
# LLM — priorité OpenAI (GPT) si OPENAI_API_KEY présente, sinon Groq si GROQ_API_KEY
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# GROQ_API_KEY=gsk_...          # optionnel, utilisé si pas d'OPENAI_API_KEY
# GROQ_MODEL=llama-3.3-70b-versatile
# PROFILE_JSON_PATH=resources/cv_base_datas_pour_candidatures.json
#
# SquidResearch (optionnel) — pour offer/submit externe
# SQUID_API_URL=https://api.squidresearch.fr
# SQUID_API_TOKEN=...

# Gmail — brouillons (IMAP) + envoi des relances (SMTP). Même mot de passe d'application.
# GMAIL_USER=ton-adresse@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Telegram Bot — controle a distance (priorite)
# TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_ALLOWED_IDS=123456789
